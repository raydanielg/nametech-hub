<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirect all traffic to public folder
    RewriteRule ^$ public/ [L]
    RewriteRule (.*) public/$1 [L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^(\.env|\.env\.example|composer\.(json|lock)|package\.json|webpack\.mix\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>
