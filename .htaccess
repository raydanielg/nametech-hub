<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect all traffic to the public folder
    RewriteRule ^$ public/index.php [L]

    # Handle assets: if the file exists in the public folder, serve it
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L]

    # Otherwise, handle everything else via public/index.php
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^(\.env|\.env\.example|composer\.(json|lock)|package\.json|webpack\.mix\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>
