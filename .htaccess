<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Handle assets (CSS, JS, Images)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} ^/(css|js|images|storage|vendor)/ [NC]
    RewriteRule ^(.*)$ public/$1 [L]

    # Handle the rest of the application
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^(\.env|\.env\.example|composer\.(json|lock)|package\.json|webpack\.mix\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>
