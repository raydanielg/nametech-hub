<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect requests for existing files in public/ to the public folder
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
    RewriteRule ^(.*)$ public/$1 [L]

    # Handle the rest of the application through public/index.php
    RewriteRule ^(.*)$ public/index.php [L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^(\.env|\.env\.example|composer\.(json|lock)|package\.json|webpack\.mix\.js)$">
    Order allow,deny
    Deny from all
</FilesMatch>
